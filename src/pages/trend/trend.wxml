<view class="page">
  <view class="header">
    <view class="header-title">饮水趋势</view>
    <view class="header-subtitle">{{showMonth ? '近30天' : '近7天'}}数据一览</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-cards">
    <view class="stat-card">
      <text class="stat-value">{{averageIntake}}</text>
      <text class="stat-unit">ml</text>
      <text class="stat-label">日均饮水量</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{completionRate}}%</text>
      <text class="stat-label">目标完成率</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{completedDays}}</text>
      <text class="stat-label">达标天数</text>
    </view>
  </view>

  <!-- 切换按钮 -->
  <view class="toggle-btn" bindtap="onToggleMode">
    <text>{{showMonth ? '查看近7天' : '查看近30天'}}</text>
  </view>

  <!-- 趋势列表 -->
  <view class="trend-list">
    <view class="trend-item {{item.isComplete ? 'complete' : ''}}" wx:for="{{trendData}}" wx:key="date">
      <view class="trend-date">{{item.displayDate}}</view>
      <view class="trend-bar-container">
        <view class="trend-bar" style="width: {{item.percentage}}%"></view>
      </view>
      <view class="trend-values">
        <text class="trend-amount">{{item.total}}ml</text>
        <text class="trend-percent {{item.isComplete ? 'complete' : ''}}">{{item.percentage}}%</text>
      </view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="hint" wx:if="{{trendData.length === 0}}">
    <text>开始记录喝水，30天后这里会展示你的饮水趋势哦～</text>
  </view>
</view>
