/* 趋势页样式 */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding: 20rpx;
}

.header {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 统计卡片 */
.stats-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4AADEA;
}

.stat-unit {
  font-size: 24rpx;
  color: #999;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 趋势列表 */
.trend-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.trend-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.trend-item:last-child {
  border-bottom: none;
}

.trend-item.complete {
  background: rgba(76, 175, 80, 0.05);
  margin: 0 -20rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

.trend-date {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
}

.trend-bar-container {
  flex: 1;
  height: 16rpx;
  background: #E8F4FD;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.trend-bar {
  height: 100%;
  background: linear-gradient(90deg, #4AADEA, #87CEEB);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.trend-item.complete .trend-bar {
  background: linear-gradient(90deg, #4CAF50, #81C784);
}

.trend-values {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 120rpx;
}

.trend-amount {
  font-size: 24rpx;
  color: #333;
}

.trend-percent {
  font-size: 22rpx;
  color: #FFB74D;
}

.trend-percent.complete {
  color: #4CAF50;
  font-weight: 600;
}

/* 提示 */
.hint {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 26rpx;
  line-height: 1.6;
}

/* 切换按钮 */
.toggle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx auto 30rpx;
  padding: 16rpx 32rpx;
  background: #4AADEA;
  border-radius: 32rpx;
  width: fit-content;
}

.toggle-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
