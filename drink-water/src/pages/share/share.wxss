/* 分享页面样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4AADEA 0%, #87CEEB 50%, #F7F8FA 100%);
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 分享海报样式 */
.poster-container {
  width: 540rpx;
  height: 720rpx;
  margin: 20rpx auto;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.share-canvas {
  display: block;
  width: 540rpx;
  height: 720rpx;
}

/* 分享信息 */
.share-info {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.share-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.share-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 16rpx 8rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.stat-icon {
  font-size: 32rpx;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #4AADEA;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
  display: block;
  margin-top: 4rpx;
}

/* 成就列表 */
.achievements-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.achievements-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.achievement-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.achievement-badge {
  font-size: 24rpx;
  color: #4AADEA;
  background: #E8F4FD;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.btn-share, .btn-save {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-share {
  background: linear-gradient(135deg, #4AADEA, #5BC8F5);
  color: #fff;
}

.btn-save {
  background: linear-gradient(135deg, #FF6B35, #FF8B5C);
  color: #fff;
}

.btn-share::after, .btn-save::after {
  border: none;
}

/* 提示 */
.tips {
  text-align: center;
  padding: 20rpx;
}

.tips text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}