<view class="page">
  <!-- 分享海报预览 -->
  <view class="poster-container">
    <canvas canvas-id="shareCanvas" class="share-canvas" style="width: 600rpx; height: 800rpx;"></canvas>
  </view>

  <!-- 分享信息 -->
  <view class="share-info">
    <view class="share-title">我的喝水成就</view>
    <view class="share-stats">
      <view class="stat-item">
        <text class="stat-icon">🔥</text>
        <text class="stat-value">{{streak}}</text>
        <text class="stat-label">连续达标</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">💧</text>
        <text class="stat-value">{{todayProgress}}%</text>
        <text class="stat-label">今日进度</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">📊</text>
        <text class="stat-value">{{totalIntake}}</text>
        <text class="stat-label">累计(ml)</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">🏆</text>
        <text class="stat-value">{{achievementCount}}</text>
        <text class="stat-label">成就数</text>
      </view>
    </view>

    <!-- 解锁的成就列表 -->
    <view class="achievements-list" wx:if="{{unlockedAchievements.length > 0}}">
      <text class="achievements-title">已解锁成就</text>
      <view class="achievement-items">
        <text class="achievement-badge" wx:for="{{unlockedAchievements}}" wx:key="id">
          {{item.icon}} {{item.name}}
        </text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-share" open-type="share">分享给好友</button>
    <button class="btn-save" bindtap="onSavePoster">保存图片</button>
  </view>

  <!-- 提示 -->
  <view class="tips">
    <text>点击"分享给好友"可直接发送给微信好友</text>
    <text>点击"保存图片"可保存到相册后分享</text>
  </view>
</view>