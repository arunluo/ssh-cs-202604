/* 任务页面样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4AADEA 0%, #87CEEB 50%, #F7F8FA 100%);
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

/* 奖励卡片 */
.rewards-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 173, 234, 0.15);
}

.rewards-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.rewards-info {
  display: flex;
  flex-direction: column;
}

.rewards-label {
  font-size: 26rpx;
  color: #666;
}

.rewards-value {
  font-size: 48rpx;
  color: #FF6B35;
  font-weight: 700;
}

/* 任务区域 */
.tasks-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 任务项 */
.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.task-item.completed {
  background: #E8F8E8;
}

.task-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
}

.task-bar {
  flex: 1;
  height: 12rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  overflow: hidden;
}

.task-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4AADEA, #5BC8F5);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.task-reward {
  margin-left: 20rpx;
}

.reward-icon {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
  background: #FFF3E8;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.task-status {
  margin-left: 16rpx;
}

.status-text {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 提示区域 */
.tips-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}