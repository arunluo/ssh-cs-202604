/* 记录页样式 */
.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding: 20rpx;
}

/* 视图切换 */
.view-switcher {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #4AADEA;
  color: #fff;
  font-weight: 600;
}

/* 今日视图 */
.today-view {
  padding: 20rpx;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-time {
  font-size: 28rpx;
  color: #333;
}

.record-amount {
  font-size: 32rpx;
  color: #4AADEA;
  font-weight: 600;
}

.delete-btn {
  padding: 12rpx 24rpx;
  background: #FF4757;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 本周视图 */
.week-view {
  padding: 20rpx;
}

.chart-container {
  width: 100%;
  height: 400rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.selected-date-records {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.date-header {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.empty-mini {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 7天汇总 */
.week-summary {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.week-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.week-day {
  font-size: 22rpx;
  color: #999;
}

.week-amount {
  font-size: 22rpx;
  color: #333;
  font-weight: 600;
  margin: 8rpx 0;
}

.week-percent {
  font-size: 20rpx;
  color: #FFB74D;
}

.week-percent.complete {
  color: #4CAF50;
}

/* 趋势视图 */
.trend-view {
  padding: 20rpx;
}

/* 周报卡片 */
.week-report-card {
  background: linear-gradient(135deg, #4AADEA, #5BC8F5);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.report-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.report-comparison {
  font-size: 26rpx;
  color: #FFD700;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.report-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.report-stats .stat-item {
  text-align: center;
}

.report-stats .stat-value {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
  display: block;
}

.report-stats .stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.report-suggestions {
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestion-title {
  font-size: 26rpx;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  display: block;
  line-height: 1.6;
}

/* 趋势图表 */
.trend-chart {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.trend-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.trend-toggle {
  font-size: 24rpx;
  color: #4AADEA;
  padding: 8rpx 20rpx;
  background: #E8F4FD;
  border-radius: 20rpx;
}

.trend-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 300rpx;
  padding: 20rpx 0;
}

.trend-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-container {
  width: 40rpx;
  height: 200rpx;
  background: #E8F4FD;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #4AADEA, #5BC8F5);
  border-radius: 8rpx;
  transition: height 0.3s;
}

.bar-fill.complete {
  background: linear-gradient(180deg, #4CAF50, #81C784);
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.bar-value {
  font-size: 18rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 趋势摘要 */
.trend-summary {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.summary-item {
  text-align: center;
  flex: 1;
}

.summary-value {
  font-size: 36rpx;
  color: #4AADEA;
  font-weight: 700;
  display: block;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
