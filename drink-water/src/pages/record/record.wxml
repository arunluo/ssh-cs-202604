<view class="page">
  <!-- 视图切换 -->
  <view class="view-switcher">
    <view
      class="tab {{activeTab === 'today' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="today"
    >
      今日
    </view>
    <view
      class="tab {{activeTab === 'week' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="week"
    >
      本周
    </view>
    <view
      class="tab {{activeTab === 'trend' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="trend"
    >
      趋势
    </view>
  </view>

  <!-- 今日视图 -->
  <view class="today-view" wx:if="{{activeTab === 'today'}}">
    <view class="record-list" wx:if="{{todayRecords.length > 0}}">
      <view
        class="record-item"
        wx:for="{{todayRecords}}"
        wx:key="id"
      >
        <view class="record-content">
          <text class="record-time">{{item.time}}</text>
          <text class="record-amount">{{item.amount}}ml</text>
        </view>
        <view
          class="delete-btn"
          bindtap="onDeleteRecord"
          data-id="{{item.id}}"
        >
          删除
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-icon">💧</text>
      <text class="empty-text">今日还没有记录哦</text>
      <text class="empty-hint">快去首页记一杯吧～</text>
    </view>
  </view>

  <!-- 本周视图 -->
  <view class="week-view" wx:if="{{activeTab === 'week'}}">
    <view class="chart-container">
      <ec-canvas
        id="weekChart"
        canvas-id="weekChart"
        bindinit="initChart"
        bindtouchstart="onWeekChartTap"
      />
    </view>

    <!-- 选中日期的记录明细 -->
    <view class="selected-date-records" wx:if="{{selectedDate}}">
      <view class="date-header">{{selectedDate}}</view>
      <view class="record-list">
        <view
          class="record-item"
          wx:for="{{selectedDateRecords}}"
          wx:key="id"
        >
          <view class="record-content">
            <text class="record-time">{{item.time}}</text>
            <text class="record-amount">{{item.amount}}ml</text>
          </view>
        </view>
        <view class="empty-mini" wx:if="{{selectedDateRecords.length === 0}}">
          当日无记录
        </view>
      </view>
    </view>

    <!-- 7天数据概览 -->
    <view class="week-summary">
      <view class="summary-title">近7天饮水数据</view>
      <view class="week-grid">
        <view
          class="week-item"
          wx:for="{{weekData}}"
          wx:key="date"
          bindtap="onWeekChartTap"
          data-index="{{index}}"
        >
          <text class="week-day">{{item.day}}</text>
          <text class="week-amount">{{item.total}}ml</text>
          <text class="week-percent {{item.percentage >= 100 ? 'complete' : ''}}">
            {{item.percentage}}%
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 趋势视图 -->
  <view class="trend-view" wx:if="{{activeTab === 'trend'}}">
    <!-- 周报卡片 -->
    <view class="week-report-card" wx:if="{{weekReport.weekAvg > 0}}">
      <view class="report-header">
        <text class="report-title">📊 本周周报</text>
        <text class="report-comparison" wx:if="{{weekReport.comparison}}">{{weekReport.comparison}}</text>
      </view>
      <view class="report-stats">
        <view class="stat-item">
          <text class="stat-value">{{weekReport.weekAvg}}</text>
          <text class="stat-label">日均(ml)</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{weekReport.completedDays}}</text>
          <text class="stat-label">达标天数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{weekReport.bestDay}}</text>
          <text class="stat-label">最佳日期</text>
        </view>
      </view>
      <view class="report-suggestions">
        <text class="suggestion-title">💡 建议</text>
        <text class="suggestion-item" wx:for="{{weekReport.suggestions}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 趋势图表 -->
    <view class="trend-chart">
      <view class="trend-header">
        <text class="trend-title">{{showMonth ? '近30天' : '近7天'}}趋势</text>
        <view class="trend-toggle" bindtap="onToggleMode">
          <text>{{showMonth ? '切换周' : '切换月'}}</text>
        </view>
      </view>
      <view class="trend-bars">
        <view
          class="trend-bar-item"
          wx:for="{{trendData}}"
          wx:key="date"
        >
          <view class="bar-container">
            <view
              class="bar-fill {{item.isComplete ? 'complete' : ''}}"
              style="height: {{item.percentage}}%"
            ></view>
          </view>
          <text class="bar-label">{{item.displayDate}}</text>
          <text class="bar-value">{{item.total}}ml</text>
        </view>
      </view>
    </view>

    <!-- 统计摘要 -->
    <view class="trend-summary">
      <view class="summary-item">
        <text class="summary-value">{{averageIntake}}</text>
        <text class="summary-label">日均摄入(ml)</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{completionRate}}%</text>
        <text class="summary-label">达标率</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{completedDays}}/{{totalDays}}</text>
        <text class="summary-label">达标天数</text>
      </view>
    </view>
  </view>
</view>